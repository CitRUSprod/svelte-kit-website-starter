{
    "name": "api",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently -k -n i18n,build,types -c green,blue,magenta -p [{name}] pnpm:dev:i18n pnpm:dev:build pnpm:dev:check-types",
        "dev:i18n": "typesafe-i18n",
        "dev:build": "tsup --config tsup/dev.ts --watch --onSuccess \"NODE_OPTIONS=--enable-source-maps pnpm start\"",
        "dev:check-types": "pnpm check-types -w --preserveWatchOutput",
        "build": "typesafe-i18n --no-watch && tsup --config tsup/prod.ts",
        "start": "node dist/main",
        "check-types": "tsc --pretty --noEmit",
        "prisma": "dotenv -e ../../.env -- prisma",
        "prisma:generate": "pnpm prisma generate",
        "prisma:studio": "pnpm prisma studio",
        "prisma:migrations": "pnpm prisma migrate",
        "prisma:migrations:create": "pnpm prisma:migrations dev",
        "prisma:migrations:run": "pnpm prisma:migrations deploy",
        "prisma:migrations:reset": "pnpm prisma:migrations reset",
        "prisma:seeds:run": "pnpm prisma db seed --",
        "prepare": "pnpm prisma:generate"
    },
    "devDependencies": {
        "@repo/configs": "workspace:*",
        "@total-typescript/ts-reset": "0.6.1",
        "@types/fs-extra": "11.0.4",
        "@types/mjml": "4.7.4",
        "@types/node": "25.5.0",
        "@types/nodemailer": "7.0.11",
        "@types/socketio-jwt-auth": "0.0.5",
        "concurrently": "9.2.1",
        "defu": "6.1.4",
        "dotenv-cli": "11.0.0",
        "dotenv-expand": "12.0.3",
        "prisma": "7.5.0",
        "tsup": "8.5.1",
        "tsx": "4.21.0",
        "type-fest": "5.5.0",
        "typescript": "5.9.3",
        "unplugin-raw": "0.6.4"
    },
    "dependencies": {
        "@fastify/auth": "5.0.4",
        "@fastify/cookie": "11.0.2",
        "@fastify/jwt": "10.0.0",
        "@fastify/multipart": "9.4.0",
        "@fastify/swagger": "9.7.0",
        "@fastify/swagger-ui": "5.2.5",
        "@prisma/adapter-pg": "7.5.0",
        "@prisma/client": "7.5.0",
        "@repo/constants": "workspace:*",
        "@repo/schemas": "workspace:*",
        "@repo/utils": "workspace:*",
        "arctic": "3.7.0",
        "argon2": "0.44.0",
        "axios": "1.13.6",
        "dotenv": "17.3.1",
        "es-toolkit": "1.45.1",
        "fastify": "5.8.2",
        "fastify-plugin": "5.1.0",
        "fastify-socket.io": "5.1.0",
        "fastify-type-provider-zod": "6.1.0",
        "fs-extra": "11.3.4",
        "http-errors-enhanced": "4.0.2",
        "minio": "8.0.7",
        "mjml": "4.18.0",
        "nodemailer": "8.0.3",
        "pg": "8.20.0",
        "sharp": "0.34.5",
        "socket.io": "4.8.3",
        "socketio-jwt-auth": "0.2.1",
        "tiny-parse-argv": "2.8.2",
        "tslib": "2.8.1",
        "typesafe-i18n": "5.27.1",
        "uuid": "13.0.0"
    }
}
