{
    "name": "web",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "concurrently -k -n i18n,build,types -c green,blue,magenta -p [{name}] pnpm:dev:i18n pnpm:dev:build pnpm:dev:check-types",
        "dev:i18n": "typesafe-i18n",
        "dev:build": "vite dev",
        "dev:check-types": "pnpm check-types --watch",
        "build": "pnpm svelte-kit:sync && typesafe-i18n --no-watch && vite build",
        "start": "PORT=6701 node dist",
        "check-types": "svelte-check --tsconfig tsconfig.json",
        "svelte-kit:sync": "NODE_ENV=production svelte-kit sync",
        "prepare": "pnpm svelte-kit:sync"
    },
    "devDependencies": {
        "@iconify/json": "2.2.452",
        "@prgm/sveltekit-progress-bar": "3.0.2",
        "@repo/configs": "workspace:*",
        "@sveltejs/adapter-node": "5.5.4",
        "@sveltejs/kit": "2.55.0",
        "@sveltejs/vite-plugin-svelte": "6.2.4",
        "@total-typescript/ts-reset": "0.6.1",
        "@types/js-cookie": "3.0.6",
        "@types/node": "25.5.0",
        "@types/set-cookie-parser": "2.4.10",
        "@unocss/extractor-svelte": "66.6.7",
        "@unocss/preset-wind3": "66.6.7",
        "@unocss/reset": "66.6.7",
        "concurrently": "9.2.1",
        "svelte": "5.54.0",
        "svelte-check": "4.4.5",
        "type-fest": "5.5.0",
        "typescript": "5.9.3",
        "unocss": "66.6.7",
        "unocss-preset-better-nested-colors": "1.0.0",
        "unocss-preset-scrollbar": "0.3.0",
        "vite": "7.3.1",
        "vite-plugin-dynamic-import": "1.6.0"
    },
    "dependencies": {
        "@macfja/svelte-persistent-store": "2.4.2",
        "@repo/constants": "workspace:*",
        "@repo/schemas": "workspace:*",
        "@repo/utils": "workspace:*",
        "axios": "1.13.6",
        "bits-ui": "2.16.3",
        "es-toolkit": "1.45.1",
        "js-cookie": "3.0.5",
        "runed": "0.37.1",
        "set-cookie-parser": "3.0.1",
        "socket.io-client": "4.8.3",
        "tslib": "2.8.1",
        "typesafe-i18n": "5.27.1"
    }
}
