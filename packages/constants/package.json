{
    "name": "@repo/constants",
    "private": true,
    "type": "module",
    "exports": {
        "./enums": "./dist/enums/index.js",
        "./routes": "./dist/routes/index.js",
        "./ws": "./dist/ws/index.js"
    },
    "typesVersions": {
        "*": {
            "*": [
                "./dist/*/index.d.ts"
            ]
        }
    },
    "scripts": {
        "build": "tsup src/*/index.ts --clean --format esm --minify --dts",
        "check-types": "tsc --pretty --noEmit"
    },
    "devDependencies": {
        "@repo/configs": "workspace:*",
        "@total-typescript/ts-reset": "0.6.1",
        "@types/node": "25.5.0",
        "tsup": "8.5.1",
        "type-fest": "5.5.0",
        "typescript": "5.9.3"
    },
    "dependencies": {
        "tslib": "2.8.1"
    }
}
